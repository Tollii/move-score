{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR/scripts/agent-hooks/runtime-hook.mjs\" --runtime claude",
						"timeout": 10,
						"statusMessage": "Running move-score pre-command hook"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$CLAUDE_PROJECT_DIR/scripts/agent-hooks/runtime-hook.mjs\" --runtime claude",
						"timeout": 60,
						"statusMessage": "Running move-score post-edit hook"
					}
				]
			}
		]
	}
}
