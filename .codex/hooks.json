{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/runtime-hook.mjs\" --runtime codex",
						"timeout": 10,
						"statusMessage": "Running move-score pre-tool hook"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/runtime-hook.mjs\" --runtime codex",
						"timeout": 60,
						"statusMessage": "Running move-score post-tool hook"
					}
				]
			}
		]
	}
}
